# ======================
# SERVER & ENVIRONMENT
# ======================
PORT=3000
NODE_ENV=production
HOST=0.0.0.0
RAILWAY_ENVIRONMENT=production
DISABLE_CHROME=true

# ======================
# BOT BEHAVIOR
# ======================
MAX_VISITORS=50
VISIT_DURATION=45000
REQUEST_TIMEOUT=30000

# ======================
# ADVANCED FEATURES (Behavior Engine)
# ======================
BEHAVIOR_ENGINE_ENABLED=true
DEFAULT_BEHAVIOR_PROFILE=explorer
TARGET_IMPRESSIONS=25
TARGET_ACTIVE_VIEW=15000

# ======================
# PROXY CONFIGURATION
# ======================
PROXY_FOLDER=./proxy
PROXY_TIMEOUT=10000
PROXY_RETRY_COUNT=3
PROXY_ROTATION_ENABLED=true

# ======================
# SECURITY & API
# ======================
# GANTI DENGAN URL RAILWAY ANDA SENDIRI (contoh: https://nama-proyek.up.railway.app)
ALLOWED_ORIGINS=https://your-project-name.up.railway.app,http://localhost:3000

# BUATLAH API KEY YANG UNIK DAN AMAN (contoh: gunakan: openssl rand -hex 32)
API_KEY=your-secure-api-key-ubah-ini-dengan-random-string-panjang

# ======================
# LOGGING
# ======================
LOG_LEVEL=debug
LOG_FILE=./logs/bot.log
LOG_ADVANCED_METRICS=true

# ======================
# RAILWAY-SPECIFIC OPTIMIZATIONS
# ======================
# Chrome tidak tersedia di Railway, jadi pastikan ini true
DISABLE_CHROME=true
ENABLE_ADVANCED_HTTP=true

# ======================
# PERFORMANCE
# ======================
WORKER_THREADS=1
MEMORY_LIMIT_MB=512
REQUEST_QUEUE_SIZE=100
